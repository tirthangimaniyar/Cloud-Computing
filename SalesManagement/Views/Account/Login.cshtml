@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="login-body">
    <div class="login-bg-art">
        <!-- SVG/CSS Background Art Simulation -->
        <svg class="svg-decoration" viewBox="0 0 800 600">
            <!-- People avatars/Icons connected by dotted lines -->
            <circle cx="100" cy="100" r="20" fill="#1abc9c" />
            <circle cx="700" cy="100" r="20" fill="#1abc9c" />
            <circle cx="100" cy="500" r="20" fill="#1abc9c" />
            <circle cx="700" cy="500" r="20" fill="#1abc9c" />
            
            <line x1="120" y1="100" x2="680" y2="100" stroke="#1abc9c" stroke-dasharray="5,5" />
            <line x1="100" y1="120" x2="100" y2="480" stroke="#1abc9c" stroke-dasharray="5,5" />
            <line x1="120" y1="500" x2="680" y2="500" stroke="#1abc9c" stroke-dasharray="5,5" />
            <line x1="700" y1="120" x2="700" y2="480" stroke="#1abc9c" stroke-dasharray="5,5" />
            
            <!-- Charts icon (rects) -->
            <rect x="380" y="50" width="10" height="30" fill="#1abc9c" />
            <rect x="400" y="30" width="10" height="50" fill="#1abc9c" />
            <rect x="420" y="60" width="10" height="20" fill="#1abc9c" />
            
            <!-- Calendar icon -->
            <rect x="380" y="520" width="40" height="30" fill="none" stroke="#1abc9c" stroke-width="2" />
            <line x1="380" y1="530" x2="420" y2="530" stroke="#1abc9c" stroke-width="2" />
            
            <!-- Gears -->
            <circle cx="50" cy="300" r="15" fill="none" stroke="#1abc9c" stroke-width="2" />
            <circle cx="750" cy="300" r="15" fill="none" stroke="#1abc9c" stroke-width="2" />
        </svg>
    </div>

    <div class="card login-card p-4">
        <h2 class="login-title">Sales Management</h2>
        
        <form asp-action="Login" method="post">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            <div class="mb-3">
                <label for="username" class="form-label text-secondary">Username</label>
                <input type="text" name="username" class="form-control border-teal" id="username" required>
            </div>
            <div class="mb-3">
                <label for="password" class="form-label text-secondary">Password</label>
                <input type="password" name="password" class="form-control border-teal" id="password" required>
            </div>
            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-signin btn-lg">Sign In</button>
                <a asp-action="Register" class="btn btn-link text-decoration-none text-success">Don't have an account? Register</a>
            </div>
        </form>
    </div>
</div>

<style>
    .border-teal {
        border-color: #1abc9c !important;
    }
    .border-teal:focus {
        box-shadow: 0 0 0 0.25rem rgba(26, 188, 156, 0.25);
    }
</style>
