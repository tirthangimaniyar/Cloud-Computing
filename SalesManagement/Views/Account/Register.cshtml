@model SalesManagement.Models.User
@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="login-body">
    <div class="login-bg-art">
        <svg class="svg-decoration" viewBox="0 0 800 600">
            <circle cx="100" cy="100" r="20" fill="#3498db" />
            <circle cx="700" cy="100" r="20" fill="#3498db" />
            <circle cx="100" cy="500" r="20" fill="#3498db" />
            <circle cx="700" cy="500" r="20" fill="#3498db" />
            <line x1="120" y1="100" x2="680" y2="100" stroke="#3498db" stroke-dasharray="5,5" />
            <line x1="100" y1="120" x2="100" y2="480" stroke="#3498db" stroke-dasharray="5,5" />
            <line x1="120" y1="500" x2="680" y2="500" stroke="#3498db" stroke-dasharray="5,5" />
            <line x1="700" y1="120" x2="700" y2="480" stroke="#3498db" stroke-dasharray="5,5" />
        </svg>
    </div>

    <div class="card login-card p-4">
        <h2 class="login-title" style="color: #3498db;">Create Account</h2>
        
        <form asp-action="Register" method="post">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            <div class="mb-3">
                <label for="username" class="form-label text-secondary">Username</label>
                <input type="text" name="Username" class="form-control border-blue" id="username" required>
            </div>
            <div class="mb-3">
                <label for="password" class="form-label text-secondary">Password</label>
                <input type="password" name="Password" class="form-control border-blue" id="password" required>
            </div>
            <div class="mb-3">
                <label for="role" class="form-label text-secondary">Role</label>
                <select name="Role" class="form-select border-blue" id="role">
                    <option value="Sales">Sales</option>
                    <option value="Manager">Manager</option>
                </select>
            </div>
            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-primary btn-lg">Sign Up</button>
                <a asp-action="Login" class="btn btn-link text-decoration-none">Already have an account? Login</a>
            </div>
        </form>
    </div>
</div>

<style>
    .border-blue {
        border-color: #3498db !important;
    }
    .border-blue:focus {
        box-shadow: 0 0 0 0.25rem rgba(52, 152, 219, 0.25);
    }
</style>
