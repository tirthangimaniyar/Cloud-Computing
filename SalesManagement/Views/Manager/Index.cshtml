@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Manager Dashboard";
}

<div class="dashboard-page">
    <div class="floating-circle circle-cyan"></div>
    <div class="floating-circle circle-pink"></div>
    
    <div class="wave-container">
         <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320" style="position:absolute; bottom:0;">
            <path fill="#1abc9c" fill-opacity="0.3" d="M0,192L48,197.3C96,203,192,213,288,229.3C384,245,480,267,576,250.7C672,235,768,181,864,181.3C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
        </svg>
    </div>

    <div class="dashboard-content px-4">
        <h1 class="display-3 fw-bold mb-3">Hello Manager</h1>
        <h3 class="fw-light mb-4">Welcome to Sales Management</h3>
        <div class="dashboard-divider"></div>

        <div class="row mt-5 justify-content-center">
            <div class="col-md-2 mb-4">
                <div class="card bg-transparent border-light text-white p-2 h-100 shadow">
                    <div class="card-body p-2">
                        <h6 class="card-title text-uppercase mb-2 small" style="color: #00f2fe;">Sales Team</h6>
                        <h3 class="fw-bold">@ViewBag.SalesUserCount</h3>
                        <a asp-action="Sales" class="btn btn-outline-info btn-sm mt-1 py-0">Manage</a>
                    </div>
                </div>
            </div>
            <div class="col-md-2 mb-4">
                <div class="card bg-transparent border-light text-white p-2 h-100 shadow">
                    <div class="card-body p-2">
                        <h6 class="card-title text-uppercase mb-2 small" style="color: #ff0080;">Total Proposals</h6>
                        <h3 class="fw-bold">@ViewBag.TotalProposals</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="card bg-transparent border-light text-white p-2 h-100 shadow">
                    <div class="card-body p-2">
                        <h6 class="card-title text-uppercase mb-2 small" style="color: #f1c40f;">Pipeline (₹)</h6>
                        <h3 class="fw-bold">₹@(((decimal)ViewBag.PipelineValue).ToString("N0"))</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-2 mb-4">
                <div class="card bg-transparent border-light text-white p-2 h-100 shadow">
                    <div class="card-body p-2">
                        <h6 class="card-title text-uppercase mb-2 small" style="color: #3498db;">Opp. Count</h6>
                        <h3 class="fw-bold">@ViewBag.TotalOpportunities</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-2 mb-4">
                <div class="card bg-transparent border-light text-white p-2 h-100 shadow">
                    <div class="card-body p-2">
                        <h6 class="card-title text-uppercase mb-2 small" style="color: #1abc9c;">Announcements</h6>
                        <h3 class="fw-bold">@ViewBag.AnnouncementCount</h3>
                        <a asp-action="Announcements" class="btn btn-outline-success btn-sm mt-1 py-0">Manage</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4 justify-content-center">
            @if (ViewBag.RecentSales != null)
            {
                <div class="col-md-6">
                    <div class="card bg-transparent border-light text-white p-3 shadow text-start">
                        <h6 class="mb-3 text-uppercase small fw-bold" style="color: #00f2fe;">Newly Joined Sales</h6>
                        <ul class="list-unstyled mb-0">
                            @foreach (var user in (List<SalesManagement.Models.User>)ViewBag.RecentSales)
                            {
                                <li class="mb-2 d-flex justify-content-between border-bottom border-secondary pb-1">
                                    <span>👤 @user.Username</span>
                                    <span class="badge bg-info">@user.Role</span>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
