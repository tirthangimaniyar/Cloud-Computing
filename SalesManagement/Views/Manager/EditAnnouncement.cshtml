@model SalesManagement.Models.Announcement
@{
    ViewData["Title"] = "Edit Announcement";
}

<div class="container mt-4">
    <div class="page-header-blue text-center">
        <h2 class="title-management">Edit Announcement</h2>
    </div>

    <div class="card shadow-sm col-md-8 mx-auto">
        <div class="card-body">
            <form asp-action="EditAnnouncement" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label class="form-label">Message</label>
                    <textarea asp-for="Message" class="form-control" rows="3" required></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Date</label>
                    <input asp-for="Date" class="form-control" required />
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Announcements" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
