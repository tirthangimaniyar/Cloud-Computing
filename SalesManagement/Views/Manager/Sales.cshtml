@model IEnumerable<SalesManagement.Models.User>
@{
    ViewData["Title"] = "Sales Management";
}

<div class="container mt-4">
    <div class="page-header-blue text-center">
        <h2 class="title-management">Sales Management</h2>
    </div>

    <div class="card shadow-sm mb-5 col-md-6 mx-auto">
        <div class="card-body">
            <h5 class="card-title mb-4">Add User</h5>
            <form asp-action="AddUser" method="post">
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <input type="text" name="Username" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" name="Password" class="form-control" required />
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Add User</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive col-md-8 mx-auto">
        <table class="table table-bordered table-hover">
            <thead class="table-custom-header">
                <tr>
                    <th>Username</th>
                    <th>Password</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Username</td>
                        <td>@user.Password</td>
                        <td>
                            <a asp-action="EditUser" asp-route-id="@user.Id" class="text-primary">Edit</a> |
                            <a asp-action="DeleteUser" asp-route-id="@user.Id" class="text-danger" onclick="return confirm('Are you sure you want to delete this user?')">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
