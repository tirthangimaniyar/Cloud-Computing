@model SalesManagement.Models.User
@{
    ViewData["Title"] = "Edit User";
}

<div class="container mt-4">
    <div class="page-header-blue text-center">
        <h2 class="title-management">Edit User</h2>
    </div>

    <div class="card shadow-sm col-md-6 mx-auto">
        <div class="card-body">
            <form asp-action="EditUser" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <input asp-for="Username" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input asp-for="Password" class="form-control" type="text" required />
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Sales" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
