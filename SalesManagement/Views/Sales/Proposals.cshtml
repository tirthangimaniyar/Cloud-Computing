@model IEnumerable<SalesManagement.Models.Proposal>
@{
    ViewData["Title"] = "Proposals Management";
}

<div class="container-fluid mt-4">
    <div class="page-header-pink text-center">
        <h2 class="title-proposals">Proposals Management</h2>
    </div>

    <div class="card shadow-sm mb-5">
        <div class="card-body">
            <form asp-action="AddProposal" method="post">
                <div class="row mb-3">
                    <div class="col-md-2">
                        <label class="form-label">Proposals Name</label>
                        <input type="text" name="Name" class="form-control" required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Chance to Close (%)</label>
                        <input type="number" name="ChanceToClose" class="form-control" required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Estimated Budget</label>
                        <input type="number" step="0.01" name="EstimatedBudget" class="form-control" required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Amount</label>
                        <input type="number" step="0.01" name="Amount" class="form-control" required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Duration in days</label>
                        <input type="number" name="Duration" class="form-control" required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Total Revenue</label>
                        <input type="number" step="0.01" name="Revenue" class="form-control" required />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-2">
                        <label class="form-label">Contact Name</label>
                        <input type="text" name="ContactName" class="form-control" required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Contact Number</label>
                        <input type="text" name="ContactMobile" class="form-control" required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Description</label>
                        <input type="text" name="Description" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Notes</label>
                        <input type="text" name="Notes" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Rejection Reason</label>
                        <input type="text" name="RejectionReason" class="form-control" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="form-check me-3">
                            <input type="checkbox" name="IsAccepted" class="form-check-input" value="true" />
                            <label class="form-check-label">Accept</label>
                        </div>
                        <button type="submit" class="btn btn-primary">Add Proposal</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover">
            <thead class="table-custom-header">
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>CreatedUserId</th>
                    <th>timestamp</th>
                    <th>ChanceToClose</th>
                    <th>EBudget</th>
                    <th>Duration</th>
                    <th>ContactName</th>
                    <th>ContactMobile</th>
                    <th>Description</th>
                    <th>Notes</th>
                    <th>Amount</th>
                    <th>Revenue</th>
                    <th>status</th>
                    <th>RejectionReason</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.CreatedUserId</td>
                        <td>@item.Timestamp.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@item.ChanceToClose%</td>
                        <td>@item.EstimatedBudget</td>
                        <td>@item.Duration</td>
                        <td>@item.ContactName</td>
                        <td>@item.ContactMobile</td>
                        <td>@item.Description</td>
                        <td>@item.Notes</td>
                        <td>@item.Amount</td>
                        <td>@item.Revenue</td>
                        <td>@(item.IsAccepted ? "Accepted" : "Pending/Rejected")</td>
                        <td>@item.RejectionReason</td>
                        <td>
                            <a asp-action="EditProposal" asp-route-id="@item.Id" class="text-primary">Edit</a> |
                            <a asp-action="DeleteProposal" asp-route-id="@item.Id" class="text-danger" onclick="return confirm('Are you sure you want to delete this proposal?')">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
