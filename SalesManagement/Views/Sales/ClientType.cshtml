@model IEnumerable<SalesManagement.Models.ClientType>
@{
    ViewData["Title"] = "Client Type Management";
}

<div class="page-background" style="background-color: #f4f8fb; min-height: 100vh; padding-bottom: 50px;">
    <div class="page-header px-4 py-3 text-center" style="background-color: #e0f0ff; border-bottom: 2px solid #b3d8f5;">
        <h2 class="title-management" style="color: #1abc9c; font-size: 26px; font-weight: bold;">Client Type Management</h2>
    </div>

    <div class="container mt-5">
        <div class="card shadow-sm mb-5 border-0 p-4" style="border-radius: 12px; background: white;">
            <h5 class="mb-4" style="color: #1abc9c; font-size: 16px; font-weight: bold;">Add Client Type</h5>
            <form asp-action="ClientType" method="post">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label text-secondary small fw-bold">Type Name</label>
                        <input type="text" name="Name" class="form-control" placeholder="e.g. B2B, B2C" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-secondary small fw-bold">Description</label>
                        <input type="text" name="Description" class="form-control" placeholder="Classification details" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn w-100 text-white fw-bold" style="background-color: #1abc9c; border-radius: 6px;">Add Type</button>
                    </div>
                </div>
            </form>
        </div>

        <div class="table-responsive rounded shadow-sm">
            <table class="table table-hover mb-0" style="background: white;">
                <thead style="background: #b3d8f5; color: #1a3a5c;">
                    <tr>
                        <th class="py-3 px-4 fw-bold">ID</th>
                        <th class="py-3 px-4 fw-bold">Name</th>
                        <th class="py-3 px-4 fw-bold">Description</th>
                        <th class="py-3 px-4 fw-bold">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="py-3 px-4">@item.Id</td>
                            <td class="py-3 px-4 fw-bold">@item.Name</td>
                            <td class="py-3 px-4">@item.Description</td>
                            <td class="py-3 px-4">
                                <a asp-action="DeleteClientType" asp-route-id="@item.Id" class="fw-bold" style="color: #e07070;" onclick="return confirm('Delete?')">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
