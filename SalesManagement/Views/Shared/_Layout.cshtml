@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sales Management System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (HttpContextAccessor.HttpContext?.Session.GetString("Username") != null)
    {
        var role = HttpContextAccessor.HttpContext.Session.GetString("Role");
        var username = HttpContextAccessor.HttpContext.Session.GetString("Username");

        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-custom border-bottom box-shadow sticky-top mb-3">
                <div class="container-fluid">
                    <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">Sales Management System</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1 justify-content-center">
                            @if (role == "Sales")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Sales" asp-action="Index">Home</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Sales" asp-action="ClientType">Client Type</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Sales" asp-action="Opportunities">Opportunities</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Sales" asp-action="Proposals">Proposals</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Sales" asp-action="Projects">Projects</a>
                                </li>
                            }
                            else if (role == "Manager")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Manager" asp-action="Index">Home</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Manager" asp-action="Sales">Sales</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Manager" asp-action="Announcements">Announcement</a>
                                </li>
                            }
                        </ul>
                        <div class="navbar-text">
                            Welcome @username | <a class="text-white" asp-controller="Account" asp-action="Logout">Log Out</a>
                        </div>
                    </div>
                </div>
            </nav>
        </header>
    }

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
